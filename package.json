{
  "name": "lattice",
  "version": "0.0.0",
  "private": true,
  "description": "A local-first, agentic learning workspace.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:web",
    "build:web": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "dev": "vite",
    "fix": "npm run format && npm run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "tauri": "tauri",
    "tauri:build:debug": "tauri build --debug",
    "tauri:dev": "tauri dev",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tauri-apps/cli": "^2.4.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "codemirror": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zustand": "^5.0.14"
  }
}
